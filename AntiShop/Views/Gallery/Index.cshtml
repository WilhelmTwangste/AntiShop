@model List<ToDoList.Domain.Entites.Image>

@{
    ViewData["Title"] = "Галерея";
}

<div class="container mt-5">
    <h2 class="mb-4">Галерея изображений для товара</h2>

    <form method="get" asp-action="Index" class="mb-4">
        <div class="form-group">
            <label for="itemId">Выберите товар:</label>
            <select class="form-control" id="itemId" name="itemId" onchange="this.form.submit()">
                <option value="">Выберите товар</option>
                @if (ViewBag.Items != null)
                {
                    foreach (var item in ViewBag.Items)
                    {
                        <option value="@item.Id" selected="@(item.Id == ViewBag.ItemId ? "selected" : null)">@item.Title (ID: @item.Id)</option>
                    }
                }
            </select>
        </div>
    </form>

    @if (Model != null && Model.Any())
    {
        <div class="row">
            @foreach (var image in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card">
                        <img src="data:image/jpeg;base64,@Convert.ToBase64String(image.ImageData)" class="card-img-top img-fluid" alt="Изображение товара" style="max-height: 300px; object-fit: cover;" />
                        <div class="card-body">
                            <form asp-action="DeleteImage" method="post" class="text-center">
                                <input type="hidden" name="id" value="@image.Id" />
                                <input type="hidden" name="itemId" value="@ViewBag.ItemId" />
                                <button type="submit" class="btn btn-light btn-sm">Удалить</button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info">Нет изображений для этого товара.</div>
    }

    @if (ViewBag.ItemId != null)
    {
        <form asp-action="UploadImage" method="post" enctype="multipart/form-data" class="mb-4">
            <input type="hidden" name="itemId" value="@ViewBag.ItemId" />
            <div class="form-group">
                <label for="file">Выберите изображение (PNG или JPG):</label>
                <input type="file" name="file" class="form-control" accept=".png,.jpg,.jpeg" required />
            </div>
            <button type="submit" class="btn btn-primary mt-3">Загрузить</button>
        </form>
    }

    <a asp-controller="Admin" asp-action="Items" class="btn btn-light">Назад к списку товаров</a>
</div>