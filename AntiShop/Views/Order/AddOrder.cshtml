@model List<ToDoList.Domain.Entites.Item>

@{
    ViewData["Title"] = "Создать заказ";
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/font-awesome/css/all.min.css" />
</head>
<body>
    <div class="container mt-5">
        <h1 class="mb-4">Создать заказ</h1>

        <form asp-action="AddOrder" method="post">
            <div class="mb-3">
                <label for="nameOrder" class="form-label">Имя заказа:</label>
                <input type="text" id="nameOrder" name="nameOrder" class="form-control" required />
            </div>

            <h3 class="mb-3">Выберите товары:</h3>
            <div class="mb-3">
                @foreach (var item in Model)
                {
                    <div class="form-check">
                        <input type="checkbox" class="form-check-input" name="selectedItemIds" value="@item.Id" id="item_@item.Id" />
                        <label class="form-check-label" for="item_@item.Id">
                            @item.Title - @item.Price руб. (в наличии: @item.Inventory)
                        </label>
                    </div>
                }
            </div>

            <button type="submit" class="btn btn-primary">
                <i class="fas fa-shopping-cart"></i> Создать заказ
            </button>
        </form>
    </div>

    <script src="~/lib/jquery/jquery.min.js"></script>
    <script src="~/lib/bootstrap/js/bootstrap.bundle.min.js"></script>
</body>
</html>